generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(uuid())
  firstName        String
  lastName         String
  email            String           @unique
  passwordHash     String
  phone            String?
  avatarFileId     String?
  isActive         Boolean          @default(true)
  emailVerified    DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  accounts         Account[]
  auditLogs        AuditLog[]       @relation("UserAuditLogs")
  cartItems        CartItem[]
  downloads        Download[]
  publishedExams   ExamPaper[]      @relation("AuthorExams")
  notifications    Notification[]
  orders           Order[]
  sessions         Session[]
  reviewedRequests TeacherRequest[] @relation("ReviewerRequests")
  teacherRequest   TeacherRequest?
  userRoles        UserRoleOnRole[]
  avatarFile       File?            @relation("UserAvatar", fields: [avatarFileId], references: [id])

  @@index([email])
  @@index([isActive])
  @@index([createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String           @id @default(uuid())
  name        RoleName         @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userRoles   UserRoleOnRole[]

  @@index([name])
  @@map("roles")
}

model UserRoleOnRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model TeacherRequest {
  id              String               @id @default(uuid())
  userId          String               @unique
  status          TeacherRequestStatus @default(PENDING)
  rejectionReason String?
  documentFileId  String?
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  documentFile    File?                @relation("TeacherRequestDocument", fields: [documentFileId], references: [id])
  reviewer        User?                @relation("ReviewerRequests", fields: [reviewedBy], references: [id])
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("teacher_requests")
}

model Category {
  id           String        @id @default(uuid())
  name         String        @unique
  slug         String        @unique
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  competitions Competition[]

  @@index([slug])
  @@map("categories")
}

model Competition {
  id         String      @id @default(uuid())
  name       String
  slug       String      @unique
  organisme  String?
  categoryId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  category   Category    @relation(fields: [categoryId], references: [id])
  examPapers ExamPaper[]
  subjects   Subject[]

  @@index([categoryId])
  @@index([slug])
  @@map("competitions")
}

model Subject {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  competitionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  examPapers    ExamPaper[]
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@index([competitionId])
  @@index([slug])
  @@map("subjects")
}

model File {
  id              String           @id @default(uuid())
  url             String
  path            String
  originalName    String?
  mimeType        String?
  size            BigInt?
  checksum        String?
  storageProvider StorageProvider  @default(LOCAL)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  correctionExams ExamPaper[]      @relation("CorrectionFile")
  paperExams      ExamPaper[]      @relation("PaperFile")
  teacherRequests TeacherRequest[] @relation("TeacherRequestDocument")
  userAvatars     User[]           @relation("UserAvatar")

  @@map("files")
}

model ExamPaper {
  id                  String          @id @default(uuid())
  title               String
  slug                String          @unique
  year                Int
  price               Decimal         @db.Decimal(10, 2)
  priceWithCorrection Decimal?        @db.Decimal(10, 2)
  status              ExamPaperStatus @default(PUBLISHED)
  authorId            String
  competitionId       String
  subjectId           String
  paperFileId         String
  correctionFileId    String?
  publishedAt         DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  professorName       String?
  professorPhone      String?
  cartItems           CartItem[]
  author              User            @relation("AuthorExams", fields: [authorId], references: [id])
  competition         Competition     @relation(fields: [competitionId], references: [id])
  correctionFile      File?           @relation("CorrectionFile", fields: [correctionFileId], references: [id])
  paperFile           File            @relation("PaperFile", fields: [paperFileId], references: [id])
  subject             Subject         @relation(fields: [subjectId], references: [id])
  orderItems          OrderItem[]

  @@index([authorId])
  @@index([competitionId])
  @@index([subjectId])
  @@index([status])
  @@index([year])
  @@index([slug])
  @@index([paperFileId])
  @@index([correctionFileId])
  @@map("exam_papers")
}

model Review {
  id          String    @id @default(uuid())
  orderItemId String    @unique
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("reviews")
}

model CartItem {
  id             String    @id @default(uuid())
  userId         String
  examPaperId    String
  withCorrection Boolean   @default(false)
  createdAt      DateTime  @default(now())
  examPaper      ExamPaper @relation(fields: [examPaperId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, examPaperId])
  @@index([userId])
  @@index([examPaperId])
  @@map("cart_items")
}

model Order {
  id           String        @id @default(uuid())
  number       String        @unique
  userId       String
  totalAmount  Decimal       @db.Decimal(10, 2)
  status       OrderStatus   @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  items        OrderItem[]
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@index([status])
  @@index([number])
  @@map("orders")
}

model OrderItem {
  id             String     @id @default(uuid())
  orderId        String
  examPaperId    String
  price          Decimal    @db.Decimal(10, 2)
  withCorrection Boolean    @default(false)
  titleSnapshot  String
  yearSnapshot   Int
  authorSnapshot String
  createdAt      DateTime   @default(now())
  downloads      Download[]
  examPaper      ExamPaper  @relation(fields: [examPaperId], references: [id])
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  review         Review?

  @@index([orderId])
  @@index([examPaperId])
  @@map("order_items")
}

model Transaction {
  id           String            @id @default(uuid())
  orderId      String
  provider     PaymentProvider   @default(NOTCHPAY)
  reference    String?
  amount       Decimal           @db.Decimal(10, 2)
  status       TransactionStatus @default(INITIATED)
  callbackData Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  commission   Commission?
  order        Order             @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@map("transactions")
}

model Commission {
  id             String      @id @default(uuid())
  transactionId  String      @unique
  rate           Decimal     @db.Decimal(5, 2)
  platformAmount Decimal     @db.Decimal(10, 2)
  teacherAmount  Decimal     @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("commissions")
}

model Download {
  id          String    @id @default(uuid())
  orderItemId String
  userId      String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([orderItemId])
  @@index([userId])
  @@index([createdAt])
  @@map("downloads")
}

model Notification {
  id            String              @id @default(uuid())
  userId        String
  type          NotificationType
  channel       NotificationChannel @default(IN_APP)
  subject       String
  content       String
  read          Boolean             @default(false)
  sentAt        DateTime?
  failedAt      DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([read])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("settings")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  details    Json?
  createdAt  DateTime    @default(now())
  user       User?       @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum RoleName {
  BUYER
  TEACHER
  ADMIN
}

enum TeacherRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExamPaperStatus {
  DRAFT
  PUBLISHED
  MASKED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum TransactionStatus {
  INITIATED
  SUCCESS
  FAILED
  EXPIRED
}

enum NotificationType {
  PAYMENT
  VALIDATION
  REJECTION
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  DOWNLOAD
  PAYMENT
  ROLE_CHANGE
  MASK
  UNMASK
}

enum StorageProvider {
  LOCAL
  S3
  R2
}

enum PaymentProvider {
  NOTCHPAY
  CAMPAY
  STRIPE
  PAYPAL
}
