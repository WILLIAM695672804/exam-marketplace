# ========================================
# Dependencies
# ========================================
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ========================================
# Next.js - Build & Output
# ========================================
/.next/
/out/
/build/
/.vercel/

# ========================================
# TypeScript - Generated files
# ========================================
*.tsbuildinfo
next-env.d.ts

# ========================================
# Environment variables (secrets)
# ========================================
.env
.env.local
.env.production
.env.development
.env*.local

# ========================================
# Uploaded user files (runtime data)
# ========================================
/uploads/*
!/uploads/.gitkeep

# ========================================
# Testing & Coverage
# ========================================
/coverage/
/test-results/
/playwright-report/
/blob-report/

# ========================================
# Debug & Logs
# ========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ========================================
# OS files
# ========================================
.DS_Store
Thumbs.db
*.swp
*~

# ========================================
# IDE / Editor configs
# ========================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ========================================
# Security
# ========================================
*.pem
*.key
*.cert
