# ===========================================================================
# Exam Marketplace — Variables d'environnement
# ===========================================================================

# ---------------------------------------------------------------------------
# Base de données
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exam_marketplace?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ---------------------------------------------------------------------------
# Générer : openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret"
AUTH_TRUST_HOST=true

# ---------------------------------------------------------------------------
# Emails (SMTP / Nodemailer)
# ---------------------------------------------------------------------------
SMTP_HOST=epreuvesconcours.moncoursier.org
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=epreuvesconcours@epreuvesconcours.moncoursier.org
SMTP_PASSWORD=your-email-password
MAIL_FROM="Muppad <epreuvesconcours@epreuvesconcours.moncoursier.org>"

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Upload
# ---------------------------------------------------------------------------
UPLOAD_DIR="uploads"

# ===========================================================================
# Module Paiement — Fapshi
# ===========================================================================

# Provider actif
PAYMENT_PROVIDER="FAPSHI"

# sandbox | production
PAYMENT_ENV="sandbox"

# DIRECT   → popup mobile money (POST /direct-pay)
# INITIATE → URL checkout hébergée (POST /initiate-pay)
FAPSHI_PAYMENT_MODE="INITIATE"

# Clés API Fapshi
# Sandbox : clés FAK_TEST_... depuis le dashboard Fapshi
# Live     : clés LIVE_... après activation du compte
FAPSHI_API_USER="your-fapshi-api-user"
FAPSHI_API_KEY="your-fapshi-api-key"
FAPSHI_WEBHOOK_SECRET="your-fapshi-webhook-secret"

# URL de l'API Fapshi (optionnel — déduit automatiquement de PAYMENT_ENV)
# Sandbox : https://sandbox.fapshi.com
# Live    : https://live.fapshi.com
# FAPSHI_BASE_URL="https://sandbox.fapshi.com"

# Timeout HTTP (ms)
FAPSHI_TIMEOUT_MS="15000"

# ===========================================================================
# Passer de Sandbox → Production
# ===========================================================================
#
# 1. Obtenir les clés Live depuis le dashboard Fapshi
# 2. Modifier les variables :
#
#    PAYMENT_ENV="production"
#    FAPSHI_API_USER="LIVE_..."
#    FAPSHI_API_KEY="LIVE_..."
#
# 3. Configurer l'URL du webhook dans le dashboard Fapshi :
#    https://votre-domaine.com/api/payments/webhook/fapshi
#
# 4. Déployer
#
# Aucune modification de code nécessaire.
# ===========================================================================
